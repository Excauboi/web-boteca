---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Taller de asistentes conversacionales con IA para pymes' } = Astro.props;
const siteName = 'La Boteca';
const fullTitle = title === 'Inicio' ? 'La Boteca — Chatbots con IA a medida para pymes' : `${title} | ${siteName}`;
---

<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="generator" content={Astro.generator} />

  <!-- Open Graph -->
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:locale" content="es_ES" />
  <meta property="og:url" content={Astro.url.href} />
  <meta property="og:site_name" content="La Boteca" />
  <meta property="og:image" content={`${Astro.site}img/logo-boteca-horizontal.png`} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:alt" content="La Boteca — Taller de asistentes conversacionales" />
  <meta name="twitter:card" content="summary" />

  <title>{fullTitle}</title>

  <!-- Inter font -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

  <link rel="icon" type="image/png" href="/favicon.png" />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="canonical" href={Astro.url.href} />
  <link rel="alternate" type="application/rss+xml" title="Blog — La Boteca" href="/rss.xml" />

  <!-- Schema.org global: Organization + WebSite -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Organization",
        "@id": "https://laboteca.es/#organization",
        "name": "La Boteca",
        "url": "https://laboteca.es",
        "logo": {
          "@type": "ImageObject",
          "url": "https://laboteca.es/img/logo-boteca-horizontal.png"
        },
        "description": "Taller de asistentes conversacionales con IA para pymes. Chatbots artesanales en Sevilla.",
        "email": "hola@laboteca.es",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "C/ Virgen del Valle, 28",
          "addressLocality": "Sevilla",
          "postalCode": "41011",
          "addressCountry": "ES"
        },
        "areaServed": {
          "@type": "Country",
          "name": "España"
        },
        "knowsAbout": [
          "Chatbots",
          "Inteligencia artificial",
          "Automatización conversacional",
          "Asistentes virtuales para empresas",
          "n8n",
          "Chatwoot"
        ],
        "sameAs": []
      },
      {
        "@type": "WebSite",
        "@id": "https://laboteca.es/#website",
        "url": "https://laboteca.es",
        "name": "La Boteca",
        "publisher": { "@id": "https://laboteca.es/#organization" },
        "inLanguage": "es"
      }
    ]
  })} />

  <slot name="schema" />

  <!-- Umami Analytics -->
  <script defer src="https://analytics.ruiberriz.org/script.js" data-website-id="ccc1d8b4-fdde-4250-8172-8aab5f683d67"></script>
</head>
<body>
  <slot name="header" />
  <main>
    <slot />
  </main>
  <slot name="footer" />

  <!-- Launcher custom La Boteca -->
  <button id="boteca-launcher" class="boteca-launcher" aria-label="Abrir chat" data-umami-event="chat-open">
    <img src="/img/animacion-boteca-64.gif" alt="" class="boteca-launcher__icon" width="32" height="32" />
    <span class="boteca-launcher__text">Pruébame</span>
  </button>

  <script>
    const io = new IntersectionObserver((entries) => {
      entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('is-visible'); io.unobserve(e.target); } });
    }, { threshold: 0.15 });
    document.querySelectorAll('.reveal, .reveal-stagger').forEach(el => io.observe(el));
  </script>

  <!-- Chatwoot SDK: is:inline para garantizar orden (settings → SDK → launcher) -->
  <script is:inline>
    window.chatwootSettings = {
      hideMessageBubble: true,
      position: "right",
      locale: "es",
      type: "standard"
    };

    (function(d,t) {
      var BASE_URL="https://support.ruiberriz.org";
      var g=d.createElement(t),s=d.getElementsByTagName(t)[0];
      g.src=BASE_URL+"/packs/js/sdk.js";
      g.defer=true;
      g.async=true;
      s.parentNode.insertBefore(g,s);
      g.onload=function(){
        window.chatwootSDK.run({
          websiteToken: 'Bjp3BSyfrxL6L9ZEmvhJJMyF',
          baseUrl: BASE_URL
        })
      }
    })(document,"script");
  </script>


  <!-- Chatwoot: inyectar contexto (URL + UTM) al cargar -->
  <script is:inline>
    window.addEventListener("chatwoot:ready", function() {
      var params = new URLSearchParams(window.location.search);
      var attrs = { pagina_origen: window.location.pathname };
      var utm_keys = ["utm_source", "utm_medium", "utm_campaign", "utm_content"];
      utm_keys.forEach(function(k) {
        var v = params.get(k);
        if (v) attrs[k] = v;
      });
      if (window.$chatwoot && window.$chatwoot.setConversationCustomAttribute) {
        window.$chatwoot.setConversationCustomAttribute(attrs);
      }
    });
  </script>

  <!-- Launcher: expandir, colapsar al scroll, abrir Chatwoot -->
  <script is:inline>
    (function() {
      var launcher = document.getElementById('boteca-launcher');
      var expanded = false;
      var expandTimer = null;
      var scrollTimer = null;
      var chatOpen = false;

      function expand() {
        if (chatOpen) return;
        launcher.classList.add('is-expanded');
        expanded = true;
      }

      function collapse() {
        launcher.classList.remove('is-expanded');
        expanded = false;
      }

      // Expandir tras 4 segundos de carga
      expandTimer = setTimeout(expand, 4000);

      // Pulso suave inicial
      launcher.classList.add('is-pulsing');

      // Scroll: colapsar inmediatamente, re-expandir 8s después de parar
      window.addEventListener('scroll', function() {
        if (expanded) collapse();
        clearTimeout(scrollTimer);
        scrollTimer = setTimeout(function() {
          if (!chatOpen) expand();
        }, 8000);
      }, { passive: true });

      // Click: abrir Chatwoot
      launcher.addEventListener('click', function() {
        if (window.$chatwoot) {
          window.$chatwoot.toggle('open');
          chatOpen = true;
          launcher.classList.add('is-hidden');
          clearTimeout(expandTimer);
          clearTimeout(scrollTimer);
        }
      });

      // Chatwoot cerrado: mostrar launcher de nuevo
      window.addEventListener('chatwoot:closed', function() {
        chatOpen = false;
        launcher.classList.remove('is-hidden');
        collapse();
        scrollTimer = setTimeout(expand, 4000);
      });

      // Chatwoot abierto externamente
      window.addEventListener('chatwoot:opened', function() {
        chatOpen = true;
        launcher.classList.add('is-hidden');
      });
    })();
  </script>
</body>
</html>
