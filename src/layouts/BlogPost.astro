---
import Base from './Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  date: string;
  author: string;
  keywords?: string;
}

const { title, description, date, author, keywords } = Astro.props;

const formattedDate = new Date(date).toLocaleDateString('es-ES', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Base title={title} description={description}>
  <Fragment slot="schema">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      "headline": title,
      "description": description,
      "datePublished": date,
      "author": {
        "@type": "Organization",
        "name": author,
        "@id": "https://laboteca.es/#organization"
      },
      "publisher": { "@id": "https://laboteca.es/#organization" },
      "mainEntityOfPage": Astro.url.href,
      "inLanguage": "es",
      ...(keywords ? { keywords: keywords } : {})
    })} />
    {keywords && <meta name="keywords" content={keywords} />}
  </Fragment>
  <Header slot="header" />

  <article class="blog-post">
    <header class="blog-post__header">
      <div class="container container--narrow">
        <a href="/blog/" class="blog-post__back">&larr; Volver al blog</a>
        <h1>{title}</h1>
        <div class="blog-post__meta">
          <time datetime={date}>{formattedDate}</time>
          <span class="blog-post__author">{author}</span>
        </div>
      </div>
    </header>

    <div class="blog-post__content">
      <div class="container container--narrow">
        <slot />
      </div>
    </div>
  </article>


  <!-- Share -->
  <aside class="blog-post__share">
    <div class="container container--narrow">
      <p class="share__label">Comparte este artículo</p>
      <div class="share__buttons">
        <a
          class="share__btn share__btn--linkedin"
          data-umami-event="share-blog"
          data-umami-event-network="linkedin"
          href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(Astro.url.href)}`}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Compartir en LinkedIn"
        >LinkedIn</a>
        <a
          class="share__btn share__btn--x"
          data-umami-event="share-blog"
          data-umami-event-network="x"
          href={`https://x.com/intent/tweet?url=${encodeURIComponent(Astro.url.href)}&text=${encodeURIComponent(title + " — La Boteca")}`}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Compartir en X"
        >X</a>
        <button
          class="share__btn share__btn--copy"
          data-umami-event="share-blog"
          data-umami-event-network="copy"
          data-url={Astro.url.href}
          aria-label="Copiar enlace"
        >Copiar enlace</button>
      </div>
    </div>
  </aside>

  <script is:inline>
    document.querySelectorAll(".share__btn--copy").forEach(function(btn) {
      btn.addEventListener("click", function() {
        var url = btn.getAttribute("data-url");
        navigator.clipboard.writeText(url).then(function() {
          btn.textContent = "Copiado";
          setTimeout(function() { btn.textContent = "Copiar enlace"; }, 2000);
        });
      });
    });
  </script>

  <!-- CTA post -->
  <section class="cta-section cta-section--dark reveal">
    <div class="container">
      <h2>¿Necesitas un chatbot que funcione de verdad?</h2>
      <p>Cuéntanos tu caso. Una llamada de 30 minutos, sin compromiso.</p>
      <a href="/contacto/" class="btn btn--primary btn--lg">Hablemos</a>
    </div>
  </section>

  <Footer slot="footer" />
</Base>

<style>
  .blog-post__header {
    padding: var(--space-2xl) 0 var(--space-xl);
    background: var(--color-bg-alt);
  }

  .blog-post__back {
    display: inline-block;
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-lg);
    transition: color var(--transition-fast);
  }

  .blog-post__back:hover {
    color: var(--color-primary);
  }

  .blog-post__header h1 {
    margin-bottom: var(--space-md);
    font-size: clamp(1.75rem, 4vw, 2.75rem);
  }

  .blog-post__meta {
    display: flex;
    gap: var(--space-md);
    font-size: 0.9rem;
    color: var(--color-text-secondary);
  }

  .blog-post__author::before {
    content: "·";
    margin-right: var(--space-md);
  }

  .blog-post__content {
    padding: var(--space-xl) 0 var(--space-2xl);
  }

  /* Prose styles for markdown content */
  .blog-post__content :global(h2) {
    margin-top: 4.5rem;
    margin-bottom: 1.5rem;
    padding-top: 0;
    font-size: clamp(1.4rem, 2.5vw, 1.9rem);
    letter-spacing: -0.02em;
  }

  .blog-post__content :global(h3) {
    margin-top: var(--space-lg);
    margin-bottom: var(--space-sm);
    font-size: clamp(1.1rem, 2vw, 1.35rem);
  }

  .blog-post__content :global(p) {
    margin-bottom: 1.5rem;
    font-size: 1.08rem;
    line-height: 1.85;
    color: var(--color-text);
  }

  .blog-post__content :global(ul),
  .blog-post__content :global(ol) {
    margin: 1.75rem 0;
    padding-left: 0;
  }

  .blog-post__content :global(ol) {
    counter-reset: list-counter;
    list-style: none;
  }

  .blog-post__content :global(ol > li) {
    counter-increment: list-counter;
    padding-left: 2.25rem;
    position: relative;
    margin-bottom: 1.25rem;
  }

  .blog-post__content :global(ol > li)::before {
    content: counter(list-counter) ".";
    position: absolute;
    left: 0;
    font-weight: 700;
    color: var(--color-primary-dark);
    font-variant-numeric: tabular-nums;
  }

  .blog-post__content :global(ul > li) {
    padding-left: 1.5rem;
    position: relative;
    list-style: none;
    margin-bottom: 0.85rem;
  }

  .blog-post__content :global(ul > li)::before {
    content: "—";
    position: absolute;
    left: 0;
    color: var(--color-text-secondary);
  }

  .blog-post__content :global(li) {
    font-size: 1.05rem;
    line-height: 1.75;
  }

  .blog-post__content :global(li:last-child) {
    margin-bottom: 0;
  }

  .blog-post__content :global(strong) {
    font-weight: 700;
  }

  .blog-post__content :global(em) {
    font-style: italic;
  }

  .blog-post__content :global(blockquote) {
    border-left: 3px solid var(--color-primary);
    padding: var(--space-md) var(--space-lg);
    margin: 2.5rem 0;
    background: var(--color-bg-alt);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
  }

  .blog-post__content :global(blockquote p) {
    margin-bottom: 0;
    color: var(--color-text-secondary);
    font-style: italic;
    font-size: 1.1rem;
  }

  .blog-post__content :global(hr) {
    border: none;
    border-top: none;
    height: 1px;
    background: var(--color-border);
    margin: 4rem auto;
    max-width: 5rem;
    display: block;
  }

  .blog-post__content table {
    width: 100%;
    border-collapse: collapse;
    margin: var(--space-lg) 0;
    font-size: 0.9rem;
  }

  .blog-post__content th {
    background: var(--color-bg-alt);
    padding: 0.75rem 1rem;
    text-align: left;
    font-weight: 600;
    border-bottom: 2px solid var(--color-border);
  }

  .blog-post__content td {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--color-border);
    vertical-align: top;
  }

  .blog-post__content a {
    color: var(--color-primary);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .blog-post__content a:hover {
    color: var(--color-primary-dark);
  }

  /* Dark CTA section */
  .cta-section--dark {
    background: var(--color-bg-dark);
    padding: var(--space-2xl) 0;
    text-align: center;
  }

  .cta-section--dark h2 {
    color: var(--color-bg);
  }

  .cta-section--dark p {
    color: rgba(255, 255, 255, 0.7);
    font-size: 1.15rem;
    max-width: 500px;
    margin: 0 auto var(--space-lg);
  }

  .btn--lg {
    padding: 1rem 2.5rem;
    font-size: 1.1rem;
  }

  /* Share bar */
  .blog-post__share {
    padding: var(--space-lg) 0;
    border-top: 1px solid var(--color-border);
  }

  .share__label {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-sm);
  }

  .share__buttons {
    display: flex;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }

  .share__btn {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 1rem;
    border-radius: var(--radius-md);
    font-size: 0.85rem;
    font-weight: 500;
    text-decoration: none;
    cursor: pointer;
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    color: var(--color-text);
    font-family: var(--font-body);
    transition: border-color var(--transition-fast), background var(--transition-fast);
  }

  .share__btn:hover {
    border-color: var(--color-primary);
    background: var(--color-bg-alt);
    color: var(--color-text);
  }

  .share__btn--linkedin:hover { border-color: #0a66c2; }
  .share__btn--x:hover { border-color: #000; }
</style>
