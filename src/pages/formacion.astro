---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Base title="Formación" description="Cursos de inteligencia artificial para equipos de organizaciones y empresas. Desde prompting hasta estrategia de adopción. 12 horas, presencial u online.">
  <Fragment slot="schema">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "ItemList",
      "name": "Cursos de formación en IA — La Boteca",
      "description": "Catálogo de cursos de inteligencia artificial para equipos de organizaciones y empresas.",
      "numberOfItems": 3,
      "itemListElement": [
            {
                  "@type": "Course",
                  "position": 1,
                  "name": "Primeros auxilios — IA para tu equipo",
                  "description": "Curso de fundamentos de IA generativa para equipos de organizaciones y empresas.",
                  "provider": {
                        "@id": "https://laboteca.es/#organization"
                  },
                  "hasCourseInstance": {
                        "@type": "CourseInstance",
                        "courseMode": [
                              "onsite",
                              "online"
                        ],
                        "duration": "PT12H",
                        "courseWorkload": "PT12H"
                  },
                  "educationalLevel": "Básico-Intermedio",
                  "inLanguage": "es",
                  "offers": {
                        "@type": "Offer",
                        "price": "1200",
                        "priceCurrency": "EUR",
                        "description": "1.200 € por participante, IVA no incluido. Pack equipo: 2 personas -25%, 3-4 personas -37%."
                  }
            },
            {
                  "@type": "Course",
                  "position": 2,
                  "name": "Curso de boticario — Construye tus propios asistentes IA",
                  "description": "Curso avanzado de asistentes IA corporativos, bases de conocimiento y estrategia de adopción.",
                  "provider": {
                        "@id": "https://laboteca.es/#organization"
                  },
                  "hasCourseInstance": {
                        "@type": "CourseInstance",
                        "courseMode": [
                              "onsite",
                              "online"
                        ],
                        "duration": "PT12H",
                        "courseWorkload": "PT12H"
                  },
                  "educationalLevel": "Intermedio-Avanzado",
                  "inLanguage": "es",
                  "offers": {
                        "@type": "Offer",
                        "price": "1500",
                        "priceCurrency": "EUR",
                        "description": "1.500 € por participante, IVA no incluido. Pack equipo: 2 personas -25%, 3-4 personas -37%."
                  }
            },
            {
                  "@type": "Course",
                  "position": 3,
                  "name": "Vibe working — Trabajar con IA en flujo continuo",
                  "description": "Curso de trabajo en flujo continuo con IA. Delegación de tareas reales, memoria persistente y asistentes personalizados.",
                  "provider": {
                        "@id": "https://laboteca.es/#organization"
                  },
                  "hasCourseInstance": {
                        "@type": "CourseInstance",
                        "courseMode": [
                              "onsite",
                              "online"
                        ],
                        "duration": "PT12H",
                        "courseWorkload": "PT12H"
                  },
                  "educationalLevel": "Intermedio",
                  "inLanguage": "es",
                  "offers": {
                        "@type": "Offer",
                        "price": "1200",
                        "priceCurrency": "EUR",
                        "description": "1.200 € por participante, IVA no incluido. Pack equipo: 2 personas -25%, 3-4 personas -37%."
                  }
            }
      ]
})} />
  </Fragment>
  <Header slot="header" />

  <!-- Page header -->
  <section class="page-header">
    <div class="container">
      <h1>Formación en IA</h1>
      <p>Tres cursos de 12 horas. Ejercicios con datos reales del participante, no demos. Presencial en Sevilla u online.</p>
    </div>
  </section>

  <div class="page-content">
    <div class="container">

      <!-- Intro -->
      <section class="section">
        <div class="highlight highlight--tip">
          <h3>Qué es esto</h3>
          <p>Cada curso son 4 sesiones de 3 horas. El material cubre fundamentos, prompting, contexto, asistentes, agentes, estrategia y herramientas. Grupos de 8 a 12 personas, no necesariamente de la misma organización.</p>
        </div>
      </section>

      <!-- Cursos -->
      <section class="section">
        <h2>Catálogo de cursos</h2>
        <div class="cards reveal-stagger">

          <!-- Primeros auxilios -->
          <article class="card card--curso" id="primeros-auxilios">
            <div class="card__badge-row">
              <span class="badge badge--nivel badge--basico">Básico-Intermedio</span>
              <span class="badge badge--formato">12h · 4 sesiones</span>
            </div>
            <h3>Primeros auxilios</h3>
            <p class="card__subtitle">Fundamentos, prompting y herramientas</p>
            <p>Qué es la IA generativa, cómo escribir instrucciones que funcionen, cómo darle contexto, y qué herramientas existen. Al final cada participante hace su plan de aplicación con sus tareas reales.</p>
            <ul>
              <li>Qué es la IA generativa, qué hace bien y dónde falla</li>
              <li>Anatomía de un prompt: las 6 piezas y cómo combinarlas</li>
              <li>Contexto: cómo dar a la IA información de tu negocio sin perder el control</li>
              <li>Herramientas: generación de imágenes, análisis de datos, búsqueda</li>
              <li>Taller final: plan de aplicación con las tareas reales de cada participante</li>
            </ul>
            <div class="card__meta">
              <span><strong>Para:</strong> Equipos de organizaciones, autónomos, departamentos operativos</span>
              <span><strong>Formato:</strong> Online o presencial en Sevilla · 8-12 personas</span>
              <span><strong>Requisitos:</strong> Ninguno. Se empieza desde cero</span>
            </div>
            <details class="card__details">
              <summary>Ver programa completo</summary>
              <div class="card__programa">
                <div class="sesion">
                  <h4>Sesión 1 — Qué es esto y qué puede hacer</h4>
                  <p>Qué es la IA generativa · Qué cambió entre 2022 y 2026 · Las 7 cosas que hace (resumir, redactar, analizar, idear, transformar, investigar, automatizar) · Panorama de herramientas · Primeros prompts</p>
                </div>
                <div class="sesion">
                  <h4>Sesión 2 — Escribir instrucciones que funcionen</h4>
                  <p>Las 6 piezas de un prompt (rol, público, contexto, tarea, formato, ajustes) · Plantillas y modelos de salida · Ejemplos para que aprenda tu estilo · Instrucciones paso a paso · Ingeniería inversa · <strong>Ejercicio:</strong> cada participante reescribe 3 prompts con sus tareas reales</p>
                </div>
                <div class="sesion">
                  <h4>Sesión 3 — Contexto: que la IA sepa de qué hablas</h4>
                  <p>Qué es el contexto y por qué importa más que el prompt · Fuentes de contexto (archivos, URLs, conversación previa) · Límites de la ventana de contexto · Memoria y persistencia entre sesiones · Proyectos y flujos de trabajo</p>
                </div>
                <div class="sesion">
                  <h4>Sesión 4 — Herramientas y plan de aplicación</h4>
                  <p>Generación de imágenes y vídeo · Búsqueda con IA · Cuadernos y análisis de datos · <strong>Taller final:</strong> cada participante identifica 3 tareas de su trabajo y construye su plan de aplicación</p>
                </div>
              </div>
            </details>
            <a href="/contacto/" class="btn btn--primary btn--sm">Solicitar información</a>
          </article>

          <!-- Curso de boticario -->
          <article class="card card--curso" id="curso-boticario">
            <div class="card__badge-row">
              <span class="badge badge--nivel badge--avanzado">Intermedio-Avanzado</span>
              <span class="badge badge--formato">12h · 4 sesiones</span>
            </div>
            <h3>Curso de boticario</h3>
            <p class="card__subtitle">Asistentes, bases de conocimiento y estrategia</p>
            <p>Cómo montar asistentes IA que usen la información de tu organización. Cómo alimentarlos con documentos propios. Qué es un agente y cuándo tiene sentido. Y cómo decidir qué automatizar y qué no.</p>
            <ul>
              <li>Configurar asistentes IA con instrucciones de sistema y base de conocimiento</li>
              <li>Preparar documentos para que la IA los entienda (curación, formatos, chunking)</li>
              <li>Qué es un agente IA, en qué se diferencia de un asistente, y cuándo usarlo</li>
              <li>RGPD, política de uso y gobernanza de datos</li>
              <li>Taller final: hoja de ruta de adopción IA para tu organización</li>
            </ul>
            <div class="card__meta">
              <span><strong>Para:</strong> Responsables de innovación, IT, operaciones, dirección</span>
              <span><strong>Formato:</strong> Online o presencial en Sevilla · 8-12 personas</span>
              <span><strong>Requisitos:</strong> Haber hecho Primeros auxilios o saber usar IA generativa</span>
            </div>
            <details class="card__details">
              <summary>Ver programa completo</summary>
              <div class="card__programa">
                <div class="sesion">
                  <h4>Sesión 1 — Asistentes IA</h4>
                  <p>Qué es un asistente IA y cómo se diferencia de un chat · Arquitectura: instrucciones de sistema + base de conocimiento + flujo conversacional · Seguridad y permisos · <strong>Ejercicio:</strong> cada participante configura un asistente para una tarea recurrente de su trabajo</p>
                </div>
                <div class="sesion">
                  <h4>Sesión 2 — Bases de conocimiento</h4>
                  <p>Cómo preparar documentos para que la IA los use bien · Formatos que funcionan y formatos que no · Chunking (partir documentos grandes) · Introducción a RAG · Cómo evaluar si las respuestas son correctas</p>
                </div>
                <div class="sesion">
                  <h4>Sesión 3 — Agentes</h4>
                  <p>Qué es un agente IA · En qué se diferencia de un asistente y de una automatización clásica · Anatomía: modelo + herramientas + orquestador · Cuándo tiene sentido un agente y cuándo no · El humano en el bucle</p>
                </div>
                <div class="sesion">
                  <h4>Sesión 4 — Estrategia y hoja de ruta</h4>
                  <p>Mapeo de procesos de la organización · Identificar qué automatizar y qué no · Política de uso responsable · RGPD y cumplimiento · <strong>Taller final:</strong> cada participante mapea los procesos de su organización, identifica 3 casos de uso prioritarios y diseña su hoja de ruta a 6 meses</p>
                </div>
              </div>
            </details>
            <a href="/contacto/" class="btn btn--primary btn--sm">Solicitar información</a>
          </article>



          <!-- Vibe working -->
          <article class="card card--curso" id="vibe-working">
            <div class="card__badge-row">
              <span class="badge badge--nivel badge--intermedio">Intermedio</span>
              <span class="badge badge--formato">12h · 4 sesiones</span>
            </div>
            <h3>Vibe working</h3>
            <p class="card__subtitle">Trabajar con IA en flujo continuo</p>
            <p>La mayoría de la gente usa la IA como un buscador caro: pregunta suelta, respuesta suelta, cerrar pestaña. Este curso enseña a trabajar en flujo continuo: delegar tareas reales, acumular contexto entre sesiones y montar un entorno que aprenda de tu trabajo.</p>
            <ul>
              <li>Del uso puntual al flujo continuo: el loop contexto-colaboración-memoria</li>
              <li>Delegar trabajo real: redacción, análisis, investigación, diseño de proyectos</li>
              <li>Configurar memoria persistente y proyectos con contexto acumulado</li>
              <li>Montar asistentes personalizados para tareas recurrentes</li>
              <li>Antipatrones: qué no funciona y dónde están los límites</li>
            </ul>
            <div class="card__meta">
              <span><strong>Para:</strong> Profesionales, autónomos, consultores, equipos y profesionales</span>
              <span><strong>Formato:</strong> Online o presencial en Sevilla · 8-12 personas</span>
              <span><strong>Requisitos:</strong> Haber usado IA generativa. No hace falta saber programar</span>
            </div>
            <details class="card__details">
              <summary>Ver programa completo</summary>
              <div class="card__programa">
                <div class="sesion">
                  <h4>Sesión 1 — Del uso puntual al flujo</h4>
                  <p>Diferencia entre usar IA y trabajar con IA · Infraestructura mínima · El loop: contexto → colaboración → memoria → acumulación · <strong>Ejercicio:</strong> cada participante delega una tarea real y compara resultado y tiempo con su método habitual</p>
                </div>
                <div class="sesion">
                  <h4>Sesión 2 — Instrucciones y contexto para trabajo real</h4>
                  <p>Escribir encargos, no preguntas · Instrucciones secuenciales · Dar contexto mediante archivos y documentos · Memoria persistente entre sesiones · Proyectos con contexto acumulado</p>
                </div>
                <div class="sesion">
                  <h4>Sesión 3 — Proyectos, contenido y análisis</h4>
                  <p>Diseño de proyectos con IA · Crear documentos, informes y propuestas · Análisis estratégico · <strong>Taller:</strong> cada participante ejecuta un proyecto real en flujo durante la sesión</p>
                </div>
                <div class="sesion">
                  <h4>Sesión 4 — Límites, asistentes y plan personal</h4>
                  <p>Qué no funciona y por qué · Antipatrones comunes · Montar un asistente para una tarea recurrente · <strong>Taller final:</strong> plan personal (semana tipo, tareas delegables, rutina de trabajo con IA, 3 cambios concretos para la semana siguiente)</p>
                </div>
              </div>
            </details>
            <a href="/contacto/" class="btn btn--primary btn--sm">Solicitar información</a>
          </article>

        </div>
      </section>

      <!-- Cómo elegir -->
      <section class="section">
        <h2>¿Cuál necesitas?</h2>
        <table class="pricing-table">
          <thead>
            <tr>
              <th>Curso</th>
              <th>Para quién</th>
              <th>Nivel</th>
              <th>Lo que te llevas</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td><strong><a href="#primeros-auxilios">Primeros auxilios</a></strong></td>
              <td>Equipos sin experiencia con IA</td>
              <td>Básico-Intermedio</td>
              <td>Fundamentos + prompting + contexto + herramientas + plan personal</td>
            </tr>
            <tr>
              <td><strong><a href="#curso-boticario">Curso de boticario</a></strong></td>
              <td>Responsables de innovación, IT, dirección</td>
              <td>Intermedio-Avanzado</td>
              <td>Asistentes IA + bases de conocimiento + agentes + hoja de ruta organización</td>
            </tr>

            <tr>
              <td><strong><a href="#vibe-working">Vibe working</a></strong></td>
              <td>Profesionales, autónomos, consultores</td>
              <td>Intermedio</td>
              <td>Trabajo en flujo con IA + asistentes personalizados + plan personal</td>
            </tr>
          </tbody>
        </table>
      </section>

      <!-- Incluido -->
      <section class="section">
        <h2>Qué incluyen todos los cursos</h2>
        <ul class="feature-list reveal-stagger">
          <li class="feature-item">
            <strong>12 horas</strong> — 4 sesiones de 3 horas
          </li>
          <li class="feature-item">
            <strong>Ejercicios con datos reales</strong> — cada participante trabaja con sus documentos, sus datos y sus procesos
          </li>
          <li class="feature-item">
            <strong>Material de referencia</strong> — fichas, bibliotecas de prompts y plantillas. Se pueden usar después del curso
          </li>
          <li class="feature-item">
            <strong>Grabaciones</strong> — acceso durante 30 días tras la última sesión
          </li>
          <li class="feature-item">
            <strong>Taller final</strong> — cada participante termina con un entregable concreto (plan de aplicación, hoja de ruta o asistente configurado, según el curso)
          </li>
        </ul>
      </section>

    </div>
  </div>

  <!-- Precio -->
  <section class="section-precio">
    <div class="container container--narrow">
      <div class="highlight highlight--tip">
        <h3>Precio por curso (12 horas)</h3>
        <table class="pricing-table" style="margin-bottom: var(--space-md);">
          <thead><tr><th>Curso</th><th>Precio/persona</th><th>Con IVA</th></tr></thead>
          <tbody>
            <tr><td>Primeros auxilios</td><td><strong>1.200 &euro;</strong></td><td>1.452 &euro;</td></tr>
            <tr><td>Curso de boticario</td><td><strong>1.500 &euro;</strong></td><td>1.815 &euro;</td></tr>
            <tr><td>Vibe working</td><td><strong>1.200 &euro;</strong></td><td>1.452 &euro;</td></tr>
          </tbody>
        </table>
        <p><strong>Pack equipo</strong> (misma organizaci&oacute;n): 2 personas <strong>-25%</strong>, 3-4 personas <strong>-37%</strong>, 5+ personas: formaci&oacute;n in-company con presupuesto cerrado.</p>
        <p>Los participantes no tienen que ser de la misma organizaci&oacute;n. El contenido, el horario y el formato se adaptan al grupo.</p>
      </div>
    </div>
  </section>

  <!-- CTA final -->
  <section class="cta-section cta-section--dark reveal">
    <div class="container">
      <h2>Información y reservas</h2>
      <p>Escríbenos con cuántas personas sois, qué nivel tenéis y qué queréis conseguir. Respondemos en 24 horas.</p>
      <a href="/contacto/" class="btn btn--primary btn--lg">Contactar</a>
    </div>
  </section>

  <Footer slot="footer" />
</Base>

<style>
  /* Card subtitle */
  .card__subtitle {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    font-style: italic;
    margin-bottom: var(--space-sm);
  }

  /* Small button variant */
  .btn--sm {
    padding: 0.5rem 1.25rem;
    font-size: 0.85rem;
  }

  .btn--lg {
    padding: 1rem 2.5rem;
    font-size: 1.1rem;
  }

  /* Card CTA link */
  .card .btn {
    margin-top: var(--space-md);
  }

  /* Meta row inside cards */
  .card__meta {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    margin-top: var(--space-md);
    padding-top: var(--space-sm);
    border-top: 1px solid var(--color-border);
  }

  .card__meta span {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    background: var(--color-bg-alt);
    padding: var(--space-xs) var(--space-sm);
    border-radius: var(--radius-sm);
  }

  /* Badge row */
  .card__badge-row {
    display: flex;
    gap: var(--space-sm);
    margin-bottom: var(--space-sm);
    flex-wrap: wrap;
  }

  /* Level badges */
  .badge--nivel {
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.2rem 0.6rem;
    border-radius: var(--radius-sm);
  }

  .badge--basico {
    background: #e8f5f3;
    color: var(--color-primary-dark);
  }

  .badge--intermedio {
    background: #e3f2fd;
    color: #1565c0;
  }

  .badge--avanzado {
    background: #f3e5f5;
    color: #7b1fa2;
  }

  .badge--formato {
    background: var(--color-bg-alt);
    color: var(--color-text-secondary);
    font-size: 0.75rem;
    font-weight: 500;
    padding: 0.2rem 0.6rem;
    border-radius: var(--radius-sm);
  }

  /* Course cards larger */
  .card--curso {
    padding: var(--space-lg) var(--space-lg) var(--space-md);
  }

  .card--curso h3 {
    font-size: 1.4rem;
  }

  .card--curso > p {
    font-size: 0.95rem;
  }

  .card--curso ul {
    list-style: none;
    padding: 0;
    margin: var(--space-sm) 0 var(--space-md);
  }

  .card--curso li {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    padding: 0.25rem 0 0.25rem 1.2rem;
    position: relative;
  }

  .card--curso li::before {
    content: "→";
    position: absolute;
    left: 0;
    color: var(--color-primary);
    font-weight: 600;
  }

  /* Details/Summary for program */
  .card__details {
    margin-top: var(--space-md);
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-sm);
  }

  .card__details summary {
    cursor: pointer;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-primary);
    padding: var(--space-sm) 0;
    list-style: none;
  }

  .card__details summary::-webkit-details-marker {
    display: none;
  }

  .card__details summary::before {
    content: "▸ ";
  }

  .card__details[open] summary::before {
    content: "▾ ";
  }

  .card__programa {
    padding: var(--space-sm) 0;
  }

  .sesion {
    padding: var(--space-sm) 0;
    border-bottom: 1px solid var(--color-border);
  }

  .sesion:last-child {
    border-bottom: none;
  }

  .sesion h4 {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 0.25rem;
  }

  .sesion p {
    font-size: 0.82rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
    margin-bottom: 0;
  }

  /* Dark CTA section */
  .cta-section--dark {
    background: var(--color-bg-dark);
    padding: var(--space-2xl) 0;
  }

  .cta-section--dark h2 {
    color: var(--color-bg);
  }

  .cta-section--dark p {
    color: rgba(255, 255, 255, 0.7);
    font-size: 1.15rem;
    max-width: 500px;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .card--curso h3 {
      font-size: 1.2rem;
    }
  }
</style>
