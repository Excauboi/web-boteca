---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<Base title="Blog" description="Artículos sobre chatbots, inteligencia artificial y automatización para pymes. Consejos prácticos desde el taller de La Boteca.">
  <Header slot="header" />

  <section class="page-header">
    <div class="container">
      <h1>Blog</h1>
      <p>Lo que aprendemos preparando chatbots. Sin humo, sin jerga innecesaria.</p>
    </div>
  </section>

  <div class="page-content">
    <div class="container">
      <div class="blog-grid reveal-stagger">
        {posts.map((post) => {
          const formattedDate = new Date(post.data.date).toLocaleDateString('es-ES', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          });
          return (
            <a href={`/blog/${post.id}/`} class="blog-card">
              <article>
                <time datetime={post.data.date}>{formattedDate}</time>
                <h2>{post.data.title}</h2>
                <p>{post.data.description}</p>
                <span class="blog-card__read">Leer artículo &rarr;</span>
              </article>
            </a>
          );
        })}
      </div>
    </div>
  </div>

  <!-- CTA -->
  <section class="cta-section cta-section--dark reveal">
    <div class="container">
      <h2>¿Tienes un proyecto en mente?</h2>
      <p>Cuéntanos qué necesitas. Una llamada de 30 minutos, sin compromiso.</p>
      <a href="/contacto/" class="btn btn--primary btn--lg">Hablemos</a>
    </div>
  </section>

  <Footer slot="footer" />
</Base>

<style>
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: var(--space-lg);
  }

  .blog-card {
    display: block;
    padding: var(--space-lg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: inherit;
    transition: box-shadow var(--transition-base), border-color var(--transition-base);
  }

  .blog-card:hover {
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06);
    border-color: var(--color-primary);
    color: inherit;
  }

  .blog-card time {
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .blog-card h2 {
    font-size: 1.25rem;
    margin: var(--space-sm) 0;
    color: var(--color-text);
    line-height: 1.3;
  }

  .blog-card p {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
    margin-bottom: var(--space-md);
  }

  .blog-card__read {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-primary);
    transition: color var(--transition-fast);
  }

  .blog-card:hover .blog-card__read {
    color: var(--color-primary-dark);
  }

  /* Dark CTA */
  .cta-section--dark {
    background: var(--color-bg-dark);
    padding: var(--space-2xl) 0;
    text-align: center;
  }

  .cta-section--dark h2 {
    color: var(--color-bg);
  }

  .cta-section--dark p {
    color: rgba(255, 255, 255, 0.7);
    font-size: 1.15rem;
    max-width: 500px;
    margin: 0 auto var(--space-lg);
  }

  .btn--lg {
    padding: 1rem 2.5rem;
    font-size: 1.1rem;
  }

  @media (max-width: 768px) {
    .blog-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
